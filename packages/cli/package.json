{
  "name": "codecarto",
  "version": "0.1.1",
  "description": "Auto-generated, always in sync architecture maps for TypeScript projects — built for client presentations, not just developers.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/seven-317/CodeCarto#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seven-317/CodeCarto.git",
    "directory": "packages/cli"
  },
  "bugs": "https://github.com/seven-317/CodeCarto/issues",
  "bin": {
    "codecarto": "./dist/cli.js",
    "cct": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "engines": {
    "node": ">=20"
  },
  "keywords": ["architecture", "diagram", "nextjs", "visualization", "dependency-graph"],
  "scripts": {
    "build": "tsup && node scripts/copy-ui.mjs",
    "prepack": "node scripts/sync-readme.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chokidar": "catalog:",
    "commander": "catalog:",
    "get-port": "catalog:",
    "jiti": "catalog:",
    "open": "catalog:",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.2",
    "sirv": "catalog:",
    "ts-morph": "catalog:",
    "ws": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@codecarto/analyzer": "workspace:*",
    "@codecarto/server": "workspace:*",
    "@codecarto/shared": "workspace:*",
    "@codecarto/ui": "workspace:*",
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
